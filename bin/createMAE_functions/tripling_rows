#' Triple Rows and Annotate Biological Replicates
#'
#' This function takes a data frame and returns a new data frame where
#' each row is repeated three times to simulate biological replicates.
#' The replicate number is appended to the specified ID column.
#'
#' @param in_df A data frame to be tripled.
#' @param id_col Column used as the unique identifier (either name or index). Default is 1.
#'
#' @return A data frame with tripled rows and modified identifiers indicating replicate number.
#'
#' @examples
#' tripling_rows(data.frame(sample = c("A", "B"), value = 1:2))
#'
#' @export
tripling_rows <- function(in_df, id_col = 1) {
  # Repeat each row 3 times
  tripled_df <- in_df[rep(1:nrow(in_df), each = 3), ]
  
  # Add replicate numbers to the ID column
  replicate_suffixes <- rep(1:3, times = nrow(in_df))
  tripled_df[[id_col]] <- paste0(in_df[[id_col]][rep(1:nrow(in_df), each = 3)], "_", replicate_suffixes)
  
  return(tripled_df)
}
